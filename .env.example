# Database Configuration
DATABASE_URL=postgresql://swachh_user:swachh_pass@localhost:5432/swachhgram
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
OTP_EXPIRY_MINUTES=5

# SMS Gateway (MSG91 or Twilio)
MSG91_AUTH_KEY=your-msg91-auth-key
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=swachhgram-images
AWS_REGION=ap-south-1

# Firebase Cloud Messaging
FCM_SERVER_KEY=your-fcm-server-key

# AI Service Configuration
MODEL_PATH=/app/models
AI_RESPONSE_TIMEOUT_SECONDS=5

# Service URLs
AUTH_SERVICE_URL=http://localhost:8000
AI_SERVICE_URL=http://localhost:8001
INCIDENT_SERVICE_URL=http://localhost:8002
COLLECTION_SERVICE_URL=http://localhost:8003
SLA_SERVICE_URL=http://localhost:8004
FLEET_ADMIN_SERVICE_URL=http://localhost:8005
DASHBOARD_SERVICE_URL=http://localhost:8006

# Frontend Configuration
REACT_APP_API_BASE_URL=http://localhost:8006
REACT_APP_WS_URL=ws://localhost:8006

# Performance & Scaling
MAX_CONCURRENT_USERS=5000
MAX_CONCURRENT_TRUCKS=500
API_RESPONSE_TIME_TARGET_MS=2000
IMAGE_UPLOAD_MAX_SIZE_MB=5
IMAGE_COMPRESSION_TARGET_KB=800

# Security
TLS_VERSION=1.3
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Logging
LOG_LEVEL=INFO
ENABLE_PERFORMANCE_LOGGING=true

# SLA Configuration
DEFAULT_SLA_HOURS=6
ESCALATION_CHECK_INTERVAL_MINUTES=15
CREW_UNRESPONSIVE_TIMEOUT_MINUTES=30

# GPS Configuration
GPS_ACCURACY_THRESHOLD_METERS=50
ROUTE_VALIDATION_TOLERANCE_METERS=100

# Offline Sync
SYNC_CHECK_INTERVAL_SECONDS=60
UPLOAD_RETRY_MAX_ATTEMPTS=3
UPLOAD_RETRY_BACKOFF_SECONDS=30
